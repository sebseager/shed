#!/usr/bin/env bash
#
# shed - manage shed dotfiles
#
#   shed install    symlink shed dotfiles into $HOME (leaf-level, merge-safe)
#   shed update     repoint/refresh symlinks (e.g. after moving the shed dir)
#   shed uninstall  remove all symlinks shed created in $HOME
#
# real directories are created in $HOME and individual files are symlinked, so
# dot/, os/<os>/dot/ and private/dot/ can all contribute files to the same
# directory (e.g. ~/.ssh) without either clobbering the other.
# precedence: private/dot beats os/<os>/dot beats dot. real files are backed up.
#
# every link shed creates is recorded in a manifest so uninstall/update can find
# them again even after the shed directory has moved.
#

set -euo pipefail

# ---- colors ----------------------------------------------------------------

if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ -n "${TERM:-}" ]; then
    RST=$(tput sgr0);    BLD=$(tput bold);     ITL=$(tput sitm);
    RED=$(tput setaf 1); GRN=$(tput setaf 2);  YLW=$(tput setaf 3);
    BLU=$(tput setaf 4); CYN=$(tput setaf 6);  DIM=$(tput dim)
else
    BLD=; DIM=; RST=; RED=; GRN=; YLW=; BLU=; CYN=
fi

IND=""   # extra indent prepended to run/act output (set within the link phase)

say()    { printf '%s\n' "$*"; }
hdr()    { printf '\n%s%s%s\n' "$BLD$CYN" "$*" "$RST"; }
field()  { printf '  %s%-6s%s %s\n' "$DIM" "$1" "$RST" "$2"; }   # label + value
warn()   { printf '%swarning:%s %s\n' "$YLW" "$RST" "$*" >&2; }
die()    { printf '%serror:%s %s\n' "$RED" "$RST" "$*" >&2; exit "${2:-1}"; }
# act <color> <label> <msg> — an aligned, colorized action line
act()    { printf '%s  %s%-9s%s %s\n' "$IND" "$1" "$2" "$RST" "$3"; }

usage() {
    cat <<EOF
${BLD}shed${RST} - manage shed dotfiles

${BLD}usage:${RST} shed <command> [-n|--dry-run]

${BLD}commands:${RST}
  ${GRN}install${RST}     symlink shed dotfiles into \$HOME (merge-safe)
  ${GRN}update${RST}      repoint/refresh symlinks (e.g. after moving the shed dir)
  ${GRN}uninstall${RST}   remove all symlinks shed created in \$HOME
  ${GRN}help${RST}        show this message

${BLD}options:${RST}
  -n, --dry-run           show what would change without touching anything
  -S, --skip-modules      do not init/pull git submodules during install
EOF
}

IGNORES=()  # paths to ignore (install-time, persisted for update)

# ---- args ------------------------------------------------------------------

CMD=""
DRY_RUN=0
SKIP_SUBMODULES=0

for arg in "$@"; do
    case "$arg" in
        install|update|uninstall) CMD="$arg" ;;
        help|-h|--help)           usage; exit 0 ;;
        -n|--dry-run)             DRY_RUN=1 ;;
        -S|--skip-modules)        SKIP_SUBMODULES=1 ;;
        -I|--ignore)              WAIT_IGNORE=1 ;;
        *)
            if [ "${WAIT_IGNORE:-0}" -eq 1 ]; then
                case "$arg" in
                    "~")   IGNORES+=("$HOME") ;;
                    "~/"*) IGNORES+=("$HOME/${arg#"~/"}") ;;
                    *)     IGNORES+=("${arg%/}") ;;
                esac
                WAIT_IGNORE=0
            else
                printf '%serror:%s unknown arg: %s\n\n' "$RED" "$RST" "$arg" >&2
                usage >&2
                exit 2
            fi
            ;;
    esac
done

if [ "${WAIT_IGNORE:-0}" -eq 1 ]; then
    warn "-I given without a path; ignoring"
fi

if [ -z "$CMD" ]; then usage >&2; exit 2; fi

# ---- locate shed -----------------------------------------------------------

# resolve this file's symlink chain to find the shed root
_shed_src="${BASH_SOURCE[0]:-$0}"
while [ -L "$_shed_src" ]; do
    _shed_link="$(readlink "$_shed_src")"
    case "$_shed_link" in
        /*) _shed_src="$_shed_link" ;;
        *)  _shed_src="$(dirname "$_shed_src")/$_shed_link" ;;
    esac
done
SHED_ROOT="$(cd "$(dirname "$_shed_src")/.." >/dev/null 2>&1 && pwd)"
unset _shed_src _shed_link

SHED_OS="$(bash "$SHED_ROOT/bin/whatsmyos" 2>/dev/null || echo unknown)"
STAMP="$(date +%Y%m%d%H%M%S)"
MANIFEST="${XDG_STATE_HOME:-$HOME/.local/state}/shed/manifest"
IGNORE="${XDG_STATE_HOME:-$HOME/.local/state}/shed/ignore"

run() { if [ "$DRY_RUN" -eq 1 ]; then printf '%s  %s[dry-run]%s %s\n' "$IND" "$DIM" "$RST" "$*"; else "$@"; fi; }

# ---- manifest --------------------------------------------------------------
#
# each line is "<dst>\t<srcrel>" where srcrel is the source path relative to the
# shed root (e.g. dot/.bashrc). srcrel lets us recognize a link as ours even
# after the shed directory has moved, since the tail of its target still matches.

MANIFEST_LINES=()   # collected as "<dst>\t<srcrel>" during a link pass

# ---- ignore helpers ---------------------------------------------------------

# returns 0 if path or any child is in IGNORES
is_ignored() {
    local p="${1%/}" i
    for i in "${IGNORES[@]}"; do
        case "$p" in "$i"|"$i"/*) return 0 ;; esac
    done
    return 1
}

# populate IGNORES from state file (if present)
read_ignore() {
    IGNORES=()
    [ -e "$IGNORE" ] || return 1
    if [ ! -r "$IGNORE" ]; then
        warn "ignore file exists but is unreadable: $IGNORE"
        return 2
    fi
    local line
    while IFS= read -r line || [ -n "$line" ]; do
        [ -n "$line" ] || continue
        IGNORES+=("${line%/}")
    done < "$IGNORE"
    return 0
}

# persist IGNORES (install resets it)
write_ignore() {
    [ "$DRY_RUN" -eq 1 ] && return 0
    local dir; dir="$(dirname "$IGNORE")"
    if ! mkdir -p "$dir" 2>/dev/null; then
        warn "could not create state dir $dir (skipping ignore file)"
        return 0
    fi
    printf '%s\n' "${IGNORES[@]}" > "$IGNORE" 2>/dev/null || warn "could not write ignore: $IGNORE"
}

record_link() { MANIFEST_LINES+=("$1"$'\t'"$2"); }

# a link is "ours" if it's a symlink whose target's tail matches the srcrel we
# recorded -- true whether it points at the current shed root or a stale one.
is_our_link() {
    local dst="$1" srcrel="$2" tgt
    [ -L "$dst" ] || return 1
    tgt="$(readlink "$dst")"
    case "$tgt" in
        */"$srcrel"|"$srcrel") return 0 ;;
        *) return 1 ;;
    esac
}

# read the manifest into parallel arrays MF_DST / MF_REL; tolerates absence and
# reports (without failing) when the file exists but can't be read.
MF_DST=(); MF_REL=()
read_manifest() {
    MF_DST=(); MF_REL=()
    [ -e "$MANIFEST" ] || return 1
    if [ ! -r "$MANIFEST" ]; then
        warn "manifest exists but is unreadable: $MANIFEST"
        return 2
    fi
    local dst rel
    while IFS=$'\t' read -r dst rel || [ -n "$dst" ]; do
        [ -n "$dst" ] || continue
        MF_DST+=("$dst"); MF_REL+=("$rel")
    done < "$MANIFEST"
    return 0
}

# dedupe by dst keeping the last (highest-precedence) entry, preserving order
write_manifest() {
    [ "$DRY_RUN" -eq 1 ] && return 0
    local dir; dir="$(dirname "$MANIFEST")"
    if ! mkdir -p "$dir" 2>/dev/null; then
        warn "could not create state dir $dir (skipping manifest)"
        warn "(uninstall/update won't be able to find these links later)"
        return 0
    fi
    local content=""
    if [ "${#MANIFEST_LINES[@]}" -gt 0 ]; then
        content="$(printf '%s\n' "${MANIFEST_LINES[@]}" |
            awk -F'\t' '{l[NR]=$0; k[NR]=$1; last[$1]=NR}
                        END{for(i=1;i<=NR;i++) if(last[k[i]]==i) print l[i]}')"
    fi
    if [ -n "$content" ]; then
        printf '%s\n' "$content" > "$MANIFEST" 2>/dev/null || warn "could not write manifest: $MANIFEST"
    else
        : > "$MANIFEST" 2>/dev/null || warn "could not write manifest: $MANIFEST"
    fi
}

# ---- linking ---------------------------------------------------------------

link_one() {
    local src="$1" dst="$2" srcrel dstdir cur bak
    srcrel="${src#"$SHED_ROOT"/}"
    dstdir="$(dirname "$dst")"
    [ -d "$dstdir" ] || run mkdir -p "$dstdir"

    record_link "$dst" "$srcrel"

    if [ -L "$dst" ]; then
        cur="$(readlink "$dst")"
        [ "$cur" = "$src" ] && return 0          # already correct, idempotent
        act "$YLW" "override:" "${dst#$HOME/}"
        printf '%s            %s%s -> %s%s\n' "$IND" "$DIM" "$cur" "$src" "$RST"
        run rm -f "$dst"
    elif [ -e "$dst" ]; then
        bak="$dst.bak.$STAMP"
        act "$YLW" "backup:" "${dst#$HOME/} -> ${bak##*/}"
        run mv "$dst" "$bak"
    fi

    run ln -s "$src" "$dst"
    act "$GRN" "link:" "${dst#$HOME/}"
}

link_tree() {
    local root="$1" f rel
    [ -d "$root" ] || return 0
    printf '  %sfrom %s%s\n' "$DIM" "${root#$SHED_ROOT/}" "$RST"
    IND="  "
    while IFS= read -r -d '' f; do
        rel="${f#"$root"/}"
        local dst="$HOME/$rel"
        if is_ignored "$dst"; then
            continue  # skip if destination is under ignored path(s)
        fi
        link_one "$f" "$dst"
    done < <(find "$root" -type f -print0)
    IND=""
}

# link in ascending precedence: base, then os-specific, then private
link_all() {
    link_tree "$SHED_ROOT/dot"
    link_tree "$SHED_ROOT/os/$SHED_OS/dot"
    link_tree "$SHED_ROOT/private/dot"
}

# secure ssh: dir 700, and repo-side files 600 (ssh checks the real file)
secure_ssh() {
    local sshdir="$HOME/.ssh"
    if is_ignored "$sshdir"; then return 0; fi
    [ -e "$sshdir" ] || return 0
    hdr "securing ~/.ssh"
    run chmod 700 "$sshdir"
    local d f
    for d in "$SHED_ROOT/dot/.ssh" "$SHED_ROOT/os/$SHED_OS/dot/.ssh" "$SHED_ROOT/private/dot/.ssh"; do
        [ -d "$d" ] || continue
        while IFS= read -r -d '' f; do
            run chmod 600 "$f"
        done < <(find "$d" -type f -print0)
    done
}

# ---- submodules ------------------------------------------------------------

show_submodules() {
    [ -f "$SHED_ROOT/.gitmodules" ] || return 0
    command -v git >/dev/null 2>&1 || return 0
    if [ "$SKIP_SUBMODULES" -eq 1 ]; then
        hdr "modules $ITL(skipped)$RST"
    else
        hdr "modules"
    fi
    git config --file "$SHED_ROOT/.gitmodules" --get-regexp '^submodule\..*\.path$' |
        while read -r key path; do
            local name url
            name=${key#submodule.}; name=${name%.path}
            url=$(git config --file "$SHED_ROOT/.gitmodules" --get "submodule.$name.url" || true)
            printf '  %s%-14s%s %s\n' "$DIM" "$path" "$RST" "$url"
        done || true
}

init_submodules() {
    [ -f "$SHED_ROOT/.gitmodules" ] || return 0
    command -v git >/dev/null 2>&1 || return 0
    if [ "$DRY_RUN" -eq 1 ]; then
        run git -C "$SHED_ROOT" submodule update --init --recursive
    elif ! git -C "$SHED_ROOT" submodule update --init --recursive; then
        printf '%s\n' "$YLW"
        say "| Could not init submodules. Do you have access?"
        say "| We'll skip for now. Once you can reach the repo, run:"
        say "|   git -C \"$SHED_ROOT\" submodule update --init --recursive"
        say "| then re-run shed install."
        printf '%s\n' "$RST"
    fi
}

# ---- shared preamble / epilogue -------------------------------------------

preamble() {
    printf '%senvironment%s\n' "$BLD$CYN" "$RST"
    field "os"   "$SHED_OS"
    field "shed" "$SHED_ROOT"
    if [ "$DRY_RUN" -eq 1 ]; then printf '  %s(dry run, nothing will change)%s\n' "$DIM" "$RST"; fi
}

epilogue() {
    hdr "done"
    say "$*"
    [ "$DRY_RUN" -eq 1 ] && printf '%s(re-run without -n to apply)%s\n' "$DIM" "$RST" || true
}

# ---- commands --------------------------------------------------------------

cmd_install() {
    preamble
    show_submodules
    if [ "$SKIP_SUBMODULES" -eq 0 ]; then
        init_submodules
    fi

    # persist ignore list (install resets it)
    write_ignore

    hdr "linking"
    link_all
    write_manifest
    secure_ssh

    epilogue "installed $((${#MANIFEST_LINES[@]})) dotfile(s)"
}

cmd_update() {
    preamble
    read_ignore || true

    # snapshot the previous manifest so we can prune links dropped from shed
    read_manifest || true
    local -a old_dst=(${MF_DST[@]+"${MF_DST[@]}"}) old_rel=(${MF_REL[@]+"${MF_REL[@]}"})

    # relink the current tree; link_one repoints any stale (moved) symlinks
    hdr "relinking"
    link_all

    # prune: anything in the old manifest that no longer exists in shed
    local new_dsts=$'\n' line
    for line in ${MANIFEST_LINES[@]+"${MANIFEST_LINES[@]}"}; do
        new_dsts="$new_dsts${line%%$'\t'*}"$'\n'
    done
    if [ "${#old_dst[@]}" -gt 0 ]; then
        hdr "pruning removed dotfiles"
        local i pruned=0
        for ((i = 0; i < ${#old_dst[@]}; i++)); do
            # never prune anything under ignored paths
            if is_ignored "${old_dst[$i]}"; then continue; fi
            case "$new_dsts" in *$'\n'"${old_dst[$i]}"$'\n'*) continue ;; esac
            if is_our_link "${old_dst[$i]}" "${old_rel[$i]}"; then
                act "$RED" "remove:" "${old_dst[$i]#$HOME/}"
                run rm -f "${old_dst[$i]}"
                pruned=$((pruned + 1))
            fi
        done
        [ "$pruned" -eq 0 ] && printf '  %s(nothing to prune)%s\n' "$DIM" "$RST"
    fi

    write_manifest
    secure_ssh

    epilogue "linked $((${#MANIFEST_LINES[@]})) dotfile(s) to $SHED_ROOT"
}

cmd_uninstall() {
    preamble

    local rc=0
    read_manifest || rc=$?
    if [ "$rc" -ne 0 ]; then
        case "$rc" in
            2) die "cannot uninstall without a readable manifest" ;;
            *) hdr "nothing to do"
               say "no manifest at $MANIFEST"
               say "(run 'shed install' first)"
               return 0 ;;
        esac
    fi
    if [ "${#MF_DST[@]}" -eq 0 ]; then
        hdr "nothing to do"
        say "manifest is empty."
        run rm -f "$MANIFEST"
        return 0
    fi

    hdr "removing links"
    local i dst rel removed=0 kept=0 baks=() b
    for ((i = 0; i < ${#MF_DST[@]}; i++)); do
        dst="${MF_DST[$i]}"; rel="${MF_REL[$i]}"
        if is_our_link "$dst" "$rel"; then
            act "$RED" "remove:" "${dst#$HOME/}"
            run rm -f "$dst"
            removed=$((removed + 1))
        elif [ -e "$dst" ] || [ -L "$dst" ]; then
            act "$DIM" "skip:" "${dst#$HOME/} (not a shed link, left alone)"
            kept=$((kept + 1))
        fi
        for b in "$dst".bak.*; do [ -e "$b" ] && baks+=("$b"); done
    done

    if [ "${#baks[@]}" -gt 0 ]; then
        hdr "backups left in place"
        say "restore any of these by hand if you want them back:"
        for b in "${baks[@]}"; do printf '  %s%s%s\n' "$DIM" "$b" "$RST"; done
    fi

    run rm -f "$MANIFEST"

    local extra=""
    [ "$kept" -gt 0 ] && extra=", left $kept untouched"
    epilogue "removed $removed link(s)$extra"
}

case "$CMD" in
    install)   cmd_install ;;
    update)    cmd_update ;;
    uninstall) cmd_uninstall ;;
esac
