#!/usr/bin/env bash
#
# git - an extensible git shim
#

##
# colors
##

BLD=$(tput bold)
RST=$(tput sgr0)
RED=$(tput setaf 1)
GRN=$(tput setaf 2)
YLW=$(tput setaf 3)
MGN=$(tput setaf 5)
CYN=$(tput setaf 6)

# locate the real git binary by finding all gits in PATH and skipping this script
REAL_GIT=$(type -aP git | grep -vFx "$(realpath "$0")" | head -n 1)

if [ -z "$REAL_GIT" ]; then
    echo "error: could not find real git executable" >&2
    exit 1
fi

# ensures our custom command doesn't shadow an actual built-in git command
check_collision() {
    local cmds
    # older git versions don't have 'all'
    cmds=$("$REAL_GIT" --list-cmds=all 2>/dev/null || "$REAL_GIT" --list-cmds=main,builtins,others,aliases 2>/dev/null)
    if [ -n "$cmds" ] && echo "$cmds" | grep -qx "$1"; then
        echo "error: custom command '$1' shadows a built-in git command. aborting." >&2
        exit 1
    fi
}

# checks if the given directory is inside a git repo
is_repo() {
    local target_dir="${1:-.}"
    if [ ! -d "$target_dir" ]; then
        echo "error: directory '$target_dir' does not exist" >&2
        return 1
    fi
    if ! "$REAL_GIT" -C "$target_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "error: '$target_dir' is not inside a git repo" >&2
        return 1
    fi
    return 0
}

# adds and commits with the given message
cmd_ac() {
    check_collision "ac"
    if ! is_repo; then return 1; fi
    
    if [ -z "$1" ]; then
        echo "error: needs a commit message" >&2
        return 1
    fi
    
    "$REAL_GIT" add .
    "$REAL_GIT" commit -m "$*"
}

# git reset --mixed HEAD~n with some validation
cmd_undo() {
    check_collision "undo"
    local n="${1:-1}"
    local remote_branch
    local unpushed_count
    local pushed_commits_affected=0

    if ! is_repo; then return 1; fi

    if ! [[ "$n" =~ ^[0-9]+$ ]] || [ "$n" -eq 0 ]; then
        echo "error: invalid number of commits to undo" >&2
        return 1
    fi

    remote_branch=$("$REAL_GIT" rev-parse --symbolic-full-name --abbrev-ref "@{u}" 2>/dev/null)

    if [ -n "$remote_branch" ]; then
        unpushed_count=$("$REAL_GIT" rev-list "${remote_branch}..HEAD" 2>/dev/null | wc -l)
        if [ "$n" -gt "$unpushed_count" ]; then
            pushed_commits_affected=1
        fi
    fi

    if [ "$pushed_commits_affected" -eq 1 ]; then
        echo "you are about to undo $n commit(s) already pushed to '$remote_branch':"
        "$REAL_GIT" log --oneline -n "$n"
        echo ""
        echo "this will rewrite public history!"
        read -r -p "proceed? [y/N] " confirm
        case "$confirm" in
        [yY]) ;;
        *)
            echo "undo aborted" >&2
            return 1
            ;;
        esac
    fi

    "$REAL_GIT" reset --mixed "HEAD~$n"

    if [ "$pushed_commits_affected" -eq 1 ]; then
        echo ""
        echo "Pushed history was rewritten. The local branch is now out of sync."
        echo "Do not fetch. To safely overwrite remote history, run:"
        echo "  git push --force-with-lease"
    fi
}

# amends the last commit without editing the message
cmd_amend() {
    check_collision "amend"
    if ! is_repo; then return 1; fi
    "$REAL_GIT" add .
    "$REAL_GIT" commit --amend --no-edit
}

# hard resets and force cleans the repo
cmd_nuke() {
    check_collision "nuke"
    if ! is_repo; then return 1; fi
    echo "${RED}WARNING: This destroys all uncommitted changes AND UNTRACKED FILES!${RST}"
    echo "  ${RED}You will be reset back to:${RST}"
    "$REAL_GIT" log --oneline -1 
    echo ""
    read -r -p ">> proceed with nuke? [y/N] " confirm
    case "$confirm" in
    [yY])
        ;;
    *)
        echo "nuke aborted" >&2
        return 1
        ;;
    esac
    "$REAL_GIT" reset --hard HEAD
    "$REAL_GIT" clean -fd
}

# updates all submodules
cmd_subsync() {
    check_collision "subsync"
    if ! is_repo; then return 1; fi
    "$REAL_GIT" submodule update --init --recursive
}

cmd_help() {
    echo ""
    echo "${CYN}// ${BLD}seb's git shim${RST}${CYN} \\\\"
    echo "${CYM}\\\\ ~  ~ ~  ~ ~  ~ //${RST}"
    echo ""
    echo "${MGN}${BLD}extra goodies:${RST}"
    echo "  ac <msg>    add all and commit with message"
    echo "  undo [n]    undo n commits (default: 1)"
    echo "  amend       add all and amend without editing message"
    echo "  nuke        hard reset and delete all untracked files"
    echo "  subsync     init and update all submodules recursively"
    echo ""
    echo "${MGN}${BLD}rest of git:${RST}"

    # show real git's help
    "$REAL_GIT" "$@"
    
    # remind user they're shimmed
    echo ""
    echo "${CYN}(you're using seb's git shim)${RST}"
}

case "$1" in
    ac)
        shift
        cmd_ac "$@"
        ;;
    undo)
        shift
        cmd_undo "$@"
        ;;
    amend)
        shift
        cmd_amend "$@"
        ;;
    nuke)
        shift
        cmd_nuke "$@"
        ;;
    subsync)
        shift
        cmd_subsync "$@"
        ;;
    ""|help|--help|-h)
        cmd_help "$@"
        ;;
    *)
        # transparently pass through all other commands
        exec "$REAL_GIT" "$@"
        ;;
esac
